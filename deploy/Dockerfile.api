FROM python:3.14-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

COPY src/ /app/src/
COPY pyproject.toml /app/

RUN pip install --no-cache-dir fastapi uvicorn duckdb argon2-cffi pyjwt python-ulid pydantic[email]

ENV PYTHONPATH=/app/src
EXPOSE 9302

CMD ["uvicorn", "stratum.http_api.app:app", "--host", "0.0.0.0", "--port", "9302"]
