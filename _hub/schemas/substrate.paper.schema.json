{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://Stratum.local/schemas/substrate.paper.schema.json",
  "title": "Substrate Paper",
  "description": "Schema for an academic paper or preprint in the substrate layer. v1.",
  "type": "object",
  "required": [
    "id",
    "slug",
    "title",
    "type",
    "created_at",
    "ingested_by",
    "schema_version",
    "authors",
    "year",
    "language",
    "domains",
    "copyright_status"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "ULID, 26 chars, Crockford base32"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 2,
      "maxLength": 80,
      "description": "Human-readable identifier, unique within papers layer"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "type": {
      "const": "paper"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "ingested_by": {
      "type": "string",
      "enum": ["wiki", "hermes", "claude-code", "pipeline"]
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "authors": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "year": {
      "type": "integer",
      "minimum": 1600,
      "maximum": 2100,
      "description": "Publication or preprint year"
    },
    "language": {
      "type": "string",
      "enum": [
        "zh-Hans", "zh-Hant",
        "en", "ja", "ko",
        "fr", "de", "es", "ru",
        "la", "grc",
        "mixed", "other"
      ],
      "description": "Primary language of the paper. 'mixed' for multilingual works."
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9.-]*$"
      },
      "minItems": 1,
      "description": "Domain tags, dotted path. e.g. 'cs.ml', 'physics.quantum', 'econ.macro'"
    },
    "copyright_status": {
      "type": "string",
      "enum": [
        "public-domain",
        "copyrighted",
        "fair-use",
        "unknown"
      ]
    },
    "doi": {
      "type": "string",
      "pattern": "^10\\..+/.+$",
      "description": "Digital Object Identifier"
    },
    "arxiv_id": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{4,5}(v[0-9]+)?$",
      "description": "arXiv identifier, e.g. '2301.07041' or '2301.07041v2'"
    },
    "venue": {
      "type": "string",
      "description": "Conference, journal, or workshop name"
    },
    "abstract": {
      "type": "string",
      "description": "Paper abstract"
    },
    "pdf_path": {
      "type": "string",
      "description": "Relative path to the stored PDF file"
    },
    "total_pages": {
      "type": "integer",
      "minimum": 1
    },
    "parsing": {
      "type": "object",
      "required": ["parser", "parser_version", "parsed_at", "paragraph_count"],
      "properties": {
        "parser": {
          "type": "string",
          "enum": ["pymupdf4llm", "unstructured", "marker", "docling", "manual", "other"]
        },
        "parser_version": { "type": "string" },
        "parsed_at": { "type": "string", "format": "date-time" },
        "paragraph_count": { "type": "integer", "minimum": 0 },
        "ocr_used": { "type": "boolean" },
        "ocr_engine": { "type": "string" },
        "ocr_quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Self-reported quality, 0-1"
        },
        "manual_corrections_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form tags, lighter than domains. Avoid duplicating domain info."
    },
    "copyright_notes": {
      "type": "string",
      "description": "Free-text notes on copyright situation"
    },
    "acquired_from": {
      "type": "string",
      "description": "How/where this paper was acquired (URL, DOI resolver, etc.). Internal audit only."
    }
  }
}
