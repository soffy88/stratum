{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://Stratum.local/schemas/substrate.webpage.schema.json",
  "title": "Substrate Webpage",
  "description": "Schema for an archived webpage snapshot in the substrate layer. v1.",
  "type": "object",
  "required": [
    "id",
    "slug",
    "title",
    "type",
    "created_at",
    "ingested_by",
    "schema_version",
    "url",
    "archived_at",
    "archive_method",
    "domains",
    "site_name"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "ULID, 26 chars, Crockford base32"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 2,
      "maxLength": 80,
      "description": "Human-readable identifier, unique within webpages layer"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "type": {
      "const": "webpage"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "ingested_by": {
      "type": "string",
      "enum": ["wiki", "hermes", "claude-code", "pipeline"]
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Original URL of the archived page"
    },
    "archived_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the snapshot was taken"
    },
    "archive_method": {
      "type": "string",
      "enum": ["single-file", "wayback", "self-host", "other"],
      "description": "Method used to archive the page"
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9.-]*$"
      },
      "minItems": 1,
      "description": "Domain tags, dotted path. e.g. 'tech.ai', 'politics.us', 'science.biology'"
    },
    "site_name": {
      "type": "string",
      "minLength": 1,
      "description": "网站或出版方名称,例如 'Karpathy Blog' / '36kr' / 'NYTimes'"
    },
    "authors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "文章作者列表,可选 (个人博客有作者, 企业新闻稿可能没有)"
    },
    "language": {
      "type": "string",
      "enum": [
        "zh-Hans", "zh-Hant",
        "en", "ja", "ko",
        "fr", "de", "es", "ru",
        "la", "grc",
        "mixed", "other"
      ],
      "description": "Primary language of the page. 'mixed' for multilingual content."
    },
    "html_path": {
      "type": "string",
      "description": "Relative path to the stored HTML snapshot file"
    },
    "snapshot_size_bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "Size of the archived snapshot in bytes"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form tags, lighter than domains. Avoid duplicating domain info."
    },
    "copyright_status": {
      "type": "string",
      "enum": [
        "public-domain",
        "copyrighted",
        "fair-use",
        "unknown"
      ]
    },
    "copyright_notes": {
      "type": "string",
      "description": "Free-text notes on copyright situation"
    }
  }
}
