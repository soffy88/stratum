{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://Stratum.local/schemas/concept.place.schema.json",
  "title": "Concept — Place",
  "description": "A geographical or historical place node in the Stratum knowledge base.",
  "type": "object",
  "required": ["id", "slug", "title", "type", "created_at", "ingested_by", "schema_version", "domains"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 2,
      "maxLength": 80
    },
    "title": { "type": "string" },
    "type": { "type": "string", "const": "place" },
    "created_at": { "type": "string", "format": "date-time" },
    "ingested_by": {
      "type": "string",
      "enum": ["wiki", "hermes", "claude-code", "pipeline"]
    },
    "domains": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" },
      "minItems": 1
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "modern_name": { "type": "string" },
    "historical_names": {
      "type": "array",
      "items": { "type": "string" }
    },
    "coordinates": {
      "type": "object",
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      },
      "additionalProperties": false
    },
    "country": { "type": "string" },
    "region": { "type": "string" },
    "place_type": {
      "type": "string",
      "enum": ["city", "region", "country", "site", "building", "other"]
    },
    "related_concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
          "slug": { "type": "string" },
          "relation": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "last_reviewed_at": { "type": "string", "format": "date-time" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "draft": { "type": "boolean" }
  }
}
