{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://Stratum.local/schemas/concept.theorem.schema.json",
  "title": "Concept — Theorem",
  "description": "A mathematical or scientific theorem node in the Stratum knowledge base.",
  "type": "object",
  "required": ["id", "slug", "title", "type", "created_at", "ingested_by", "schema_version", "domains", "field"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 2,
      "maxLength": 80
    },
    "title": { "type": "string" },
    "type": { "type": "string", "const": "theorem" },
    "created_at": { "type": "string", "format": "date-time" },
    "ingested_by": {
      "type": "string",
      "enum": ["wiki", "hermes", "claude-code", "pipeline"]
    },
    "domains": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" },
      "minItems": 1
    },
    "field": {
      "type": "string",
      "pattern": "^(math|cs|physics|econ)\\..+",
      "description": "Controlled vocabulary field identifier, e.g. 'math.probability', 'cs.ml'."
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "formal_statement": {
      "type": "string",
      "description": "Formal statement of the theorem; may contain LaTeX."
    },
    "informal_summary": { "type": "string" },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
          "slug": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "related_concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
          "slug": { "type": "string" },
          "relation": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "provers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "year_proved": { "type": "integer" },
    "last_reviewed_at": { "type": "string", "format": "date-time" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "draft": { "type": "boolean" }
  }
}
