[Unit]
Description=AII flywheel — 程序化中文经济学飞轮 (econ ZH)
After=network.target aii-backend.service

[Service]
Type=simple
WorkingDirectory=/data/soffy/projects/stratum/aii
ExecStart=/usr/bin/bash scripts/econ_flywheel_zh_run.sh
StandardOutput=append:/data/soffy/projects/stratum/aii/econ_pipeline/flywheel_zh.log
StandardError=append:/data/soffy/projects/stratum/aii/econ_pipeline/flywheel_zh.log
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
