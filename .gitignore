aii/.pipeline_keys.json
aii/*_pipeline/bu_*.json
aii/*_pipeline/ckpts/
aii/*_pipeline/*_state*.json

# e2e scratch (端到端测试垃圾)
e2e_token*.txt
e2e_upload_resp*.json
e2e_docs_resp.json
e2e_pdf_path.txt

# temp (临时产物)
